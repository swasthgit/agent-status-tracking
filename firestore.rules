rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin collection - managers only
    match /admin/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Admin call logs
      match /callLogs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Managers collection - Department Managers
    match /managers/{managerId} {
      // Any authenticated user can read any manager document (needed for auth checks)
      // Managers can read their own document, and others can read for team structure
      allow read: if request.auth != null;

      // Super admins and the manager themselves can write
      allow write: if request.auth != null &&
                      (exists(/databases/$(database)/documents/admin/$(request.auth.uid)) ||
                       request.auth.uid == managerId);

      // Department Members subcollection - CRITICAL for Department Manager Dashboard
      match /departmentMembers/{memberId} {
        // Managers can read their own department members
        // Check both if managerId matches UID or if the parent document's uid field matches
        allow read: if request.auth != null &&
                       (request.auth.uid == managerId ||
                        get(/databases/$(database)/documents/managers/$(managerId)).data.uid == request.auth.uid);

        // Super admins can read/write all department members
        allow read, write: if request.auth != null &&
                           exists(/databases/$(database)/documents/admin/$(request.auth.uid));
      }
    }

    // User Collections Mapping - for fast authentication lookup
    match /userCollections/{userId} {
      // All authenticated users can read their own mapping
      allow read: if request.auth != null && request.auth.uid == userId;

      // Managers can read and write any mapping
      allow read, write: if request.auth != null &&
                           exists(/databases/$(database)/documents/admin/$(request.auth.uid));
    }

    // Legacy teamleads collection (for backward compatibility)
    match /teamleads/{userId} {
      // All authenticated users can read teamlead documents
      allow read: if request.auth != null;

      // TL can write their own document, managers can write any
      allow write: if request.auth != null &&
                      (request.auth.uid == userId ||
                       exists(/databases/$(database)/documents/admin/$(request.auth.uid)));

      // CallLogs subcollection
      match /callLogs/{logId} {
        allow read, write: if request.auth != null;
      }

      // Assigned calls
      match /assignedCalls/{docId} {
        allow read, write: if request.auth != null;
      }

      // ExoCallDetails
      match /exoCallDetails/{docId} {
        allow read, write: if request.auth != null;
      }
    }

    // Legacy agent collections (agent1-agent50) for backward compatibility
    // Note: Firestore rules don't support wildcard collection names, so individual rules needed
    // These rules apply to agent1, agent2, agent3, etc. collections
    match /{agentCollection}/{userId} {
      // Users can read/write their own document in any agent collection
      allow read, write: if request.auth != null &&
                           request.auth.uid == userId &&
                           agentCollection.matches('agent[0-9]+');

      // Admins can read/write all in any agent collection
      allow read, write: if request.auth != null &&
                         exists(/databases/$(database)/documents/admin/$(request.auth.uid)) &&
                         agentCollection.matches('agent[0-9]+');

      // CallLogs subcollection
      match /callLogs/{logId} {
        allow read, write: if request.auth != null && agentCollection.matches('agent[0-9]+');
      }

      // Assigned calls
      match /assignedCalls/{docId} {
        allow read, write: if request.auth != null && agentCollection.matches('agent[0-9]+');
      }

      // ExoCallDetails
      match /exoCallDetails/{docId} {
        allow read, write: if request.auth != null && agentCollection.matches('agent[0-9]+');
      }
    }

    // mswasth collection - for TLs and team agents
    match /mswasth/{userId} {
      // All authenticated users can read
      allow read: if request.auth != null;

      // Users can write their own document
      allow write: if request.auth != null && request.auth.uid == userId;

      // Admins can write any document
      allow write: if request.auth != null &&
                      exists(/databases/$(database)/documents/admin/$(request.auth.uid));

      // CallLogs subcollection
      match /callLogs/{logId} {
        allow read, write: if request.auth != null;
      }

      // Assigned calls
      match /assignedCalls/{docId} {
        allow read, write: if request.auth != null;
      }

      // ExoCallDetails
      match /exoCallDetails/{docId} {
        allow read, write: if request.auth != null;
      }
    }

    // Partners collection - all authenticated users can read
    match /partners/{partnerId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Health Agents collection - separate from regular agent collections
    match /healthAgents/{docId} {
      allow read: if request.auth != null;

      // Allow write if: document ID matches UID, OR document's uid field matches auth UID, OR user is admin
      allow write: if request.auth != null &&
                      (request.auth.uid == docId ||
                       resource.data.uid == request.auth.uid ||
                       exists(/databases/$(database)/documents/admin/$(request.auth.uid)));

      // Health Agent call logs
      match /callLogs/{logId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }

      // Assigned calls
      match /assignedCalls/{docId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null &&
                     exists(/databases/$(database)/documents/admin/$(request.auth.uid));
      }

      // ExoCallDetails
      match /exoCallDetails/{docId} {
        allow read, write: if request.auth != null;
      }

      // Daily Tasks subcollection for Health Agents
      match /dailyTasks/{taskDate} {
        // All authenticated users can read (TLs, Managers can view agent tasks)
        allow read: if request.auth != null;

        // Agents can write their own daily tasks
        // Check if the user's UID matches the agent document's uid field OR docId
        allow write: if request.auth != null;
      }
    }

    // Insurance Agents collection - NEW restructured collection
    match /insuranceAgents/{userId} {
      allow read: if request.auth != null;

      allow write: if request.auth != null &&
                      (request.auth.uid == userId ||
                       exists(/databases/$(database)/documents/admin/$(request.auth.uid)));

      // Insurance Agent call logs
      match /callLogs/{logId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Assigned calls
      match /assignedCalls/{docId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null &&
                     exists(/databases/$(database)/documents/admin/$(request.auth.uid));
      }

      // ExoCallDetails
      match /exoCallDetails/{docId} {
        allow read, write: if request.auth != null;
      }
    }

    // Health Team Leads collection - NEW restructured collection
    match /healthTeamLeads/{empId} {
      allow read: if request.auth != null;

      allow write: if request.auth != null &&
                      (request.auth.uid == empId ||
                       resource.data.uid == request.auth.uid ||
                       exists(/databases/$(database)/documents/admin/$(request.auth.uid)));

      // CallLogs subcollection
      match /callLogs/{logId} {
        allow read, write: if request.auth != null;
      }

      // Assigned calls
      match /assignedCalls/{docId} {
        allow read, write: if request.auth != null;
      }

      // ExoCallDetails
      match /exoCallDetails/{docId} {
        allow read, write: if request.auth != null;
      }
    }

    // Insurance Team Leads collection - NEW restructured collection
    match /insuranceTeamLeads/{userId} {
      allow read: if request.auth != null;

      allow write: if request.auth != null &&
                      (request.auth.uid == userId ||
                       exists(/databases/$(database)/documents/admin/$(request.auth.uid)));

      // CallLogs subcollection
      match /callLogs/{logId} {
        allow read, write: if request.auth != null;
      }

      // Assigned calls
      match /assignedCalls/{docId} {
        allow read, write: if request.auth != null;
      }

      // ExoCallDetails
      match /exoCallDetails/{docId} {
        allow read, write: if request.auth != null;
      }
    }

    // Exophones collection - All phone numbers (SECURE)
    match /exophones/{exophoneId} {
      allow read: if request.auth != null;

      allow write: if request.auth != null &&
                      exists(/databases/$(database)/documents/admin/$(request.auth.uid));
    }

    // Partners collection - Partner/client metadata (SECURE)
    match /partners/{partnerId} {
      allow read: if request.auth != null;

      allow write: if request.auth != null &&
                      exists(/databases/$(database)/documents/admin/$(request.auth.uid));
    }

    // Partner-Exophone linkages (SECURE)
    match /partnerNumbers/{linkId} {
      allow read: if request.auth != null;

      allow write: if request.auth != null &&
                      exists(/databases/$(database)/documents/admin/$(request.auth.uid));
    }

    // Clinic Data collection - stores clinic information for DC agents
    match /clinicData/{clinicCode} {
      // All authenticated users can read clinic data
      allow read: if request.auth != null;

      // Only admins can write clinic data
      allow write: if request.auth != null &&
                      exists(/databases/$(database)/documents/admin/$(request.auth.uid));
    }

    // Offline Visits Managers collection - managers who oversee DC agents
    match /offlineVisitsManagers/{managerId} {
      // Manager can read/write their own document
      allow read, write: if request.auth != null && request.auth.uid == managerId;

      // Admins can read/write all manager documents
      allow read, write: if request.auth != null &&
                         exists(/databases/$(database)/documents/admin/$(request.auth.uid));

      // Offline Visits Managers can read ALL offlineVisits collection data
      // This is handled by the offlineVisits collection rules below
    }

    // Offline Visits collection - NEW separate team for offline visit logging
    match /offlineVisits/{userId} {
      // Users can read/write their own document
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Admins can read/write all offline visit user documents
      allow read, write: if request.auth != null &&
                         exists(/databases/$(database)/documents/admin/$(request.auth.uid));

      // Offline Visits Managers can READ all offline visit user documents
      allow read: if request.auth != null &&
                     exists(/databases/$(database)/documents/offlineVisitsManagers/$(request.auth.uid));

      // Offline Visits subcollection - stores actual visit records
      match /offlineVisits/{visitId} {
        // User can read/write their own visits
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Admins can read/write all visits
        allow read, write: if request.auth != null &&
                           exists(/databases/$(database)/documents/admin/$(request.auth.uid));

        // Offline Visits Managers can READ all visits
        allow read: if request.auth != null &&
                       exists(/databases/$(database)/documents/offlineVisitsManagers/$(request.auth.uid));
      }

      // Visit Logs subcollection - stores DC agent clinic visit records
      match /visitLogs/{logId} {
        // User can read/write their own visit logs
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Admins can read/write all visit logs
        allow read, write: if request.auth != null &&
                           exists(/databases/$(database)/documents/admin/$(request.auth.uid));

        // Offline Visits Managers can READ all visit logs
        allow read: if request.auth != null &&
                       exists(/databases/$(database)/documents/offlineVisitsManagers/$(request.auth.uid));
      }

      // Manual Call Logs subcollection - stores manual call logs
      match /manualCallLogs/{logId} {
        // User can read/write their own logs
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Admins can read/write all logs
        allow read, write: if request.auth != null &&
                           exists(/databases/$(database)/documents/admin/$(request.auth.uid));

        // Offline Visits Managers can READ all logs
        allow read: if request.auth != null &&
                       exists(/databases/$(database)/documents/offlineVisitsManagers/$(request.auth.uid));
      }

      // Trips subcollection - stores trip tracking data with location and distance
      match /trips/{tripId} {
        // User can read/write their own trips
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Admins can read/write all trips
        allow read, write: if request.auth != null &&
                           exists(/databases/$(database)/documents/admin/$(request.auth.uid));

        // Offline Visits Managers can READ all trips
        allow read: if request.auth != null &&
                       exists(/databases/$(database)/documents/offlineVisitsManagers/$(request.auth.uid));
      }

      // Active Punch subcollection - stores active punch in/out data
      match /activePunch/{punchId} {
        // User can read/write their own punch records
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Admins can read/write all punch records
        allow read, write: if request.auth != null &&
                           exists(/databases/$(database)/documents/admin/$(request.auth.uid));

        // Offline Visits Managers can READ all punch records
        allow read: if request.auth != null &&
                       exists(/databases/$(database)/documents/offlineVisitsManagers/$(request.auth.uid));
      }
    }

    // Super Manager (admin collection) can read/write ALL documents (fallback rule)
    match /{document=**} {
      // Read access for admins and managers
      allow read: if request.auth != null &&
                  (exists(/databases/$(database)/documents/admin/$(request.auth.uid)) ||
                   exists(/databases/$(database)/documents/managers/$(request.auth.uid)));

      // Write access for admins only (full system access)
      allow write: if request.auth != null &&
                      exists(/databases/$(database)/documents/admin/$(request.auth.uid));
    }
  }
}
